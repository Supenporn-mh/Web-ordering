{
  "system": "Web Ordering SaaS",
  "theme": "light-mode-first",
  "colors": {
    "primary": {
      "light": "#ffefea",
      "main": "#ff5a2c",
      "dark": "#d13c12",
      "contrastText": "#ffffff"
    },
    "secondary": {
      "main": "#1d2939",
      "contrastText": "#ffffff"
    },
    "background": {
      "default": "#f9fafb",
      "paper": "#ffffff",
      "bottomSheet": "#ffffff"
    },
    "text": {
      "primary": "#101828",
      "secondary": "#667085",
      "disabled": "#98a2b3"
    },
    "status": {
      "success": "#12b76a",
      "warning": "#f79009",
      "error": "#f04438",
      "outOfStock": "#667085"
    },
    "borders": {
      "divider": "#eaecf0",
      "input": "#d0d5dd"
    }
  },
  "typography": {
    "fontFamily": "'Inter', 'Prompt', sans-serif",
    "h1": {
      "fontSize": "24px",
      "fontWeight": 700,
      "lineHeight": "32px"
    },
    "h2": {
      "fontSize": "20px",
      "fontWeight": 600,
      "lineHeight": "28px"
    },
    "body1": {
      "fontSize": "16px",
      "fontWeight": 400,
      "lineHeight": "24px"
    },
    "body2": {
      "fontSize": "14px",
      "fontWeight": 400,
      "lineHeight": "20px"
    },
    "button": {
      "fontSize": "16px",
      "fontWeight": 600,
      "lineHeight": "24px"
    },
    "caption": {
      "fontSize": "12px",
      "fontWeight": 400,
      "lineHeight": "18px"
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px"
  },
  "borderRadius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "pill": "9999px"
  },
  "shadows": {
    "card": "0px 1px 3px rgba(16, 24, 40, 0.1), 0px 1px 2px rgba(16, 24, 40, 0.06)",
    "bottomSheet": "0px -4px 16px rgba(16, 24, 40, 0.1)"
  }
}
